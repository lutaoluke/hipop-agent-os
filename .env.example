# 点购 Agent OS — 环境变量模板
# 复制为 .env，填入真实值（.env 已 .gitignore）

# ─── LLM provider ──────────────────────────────────────
# 阶段 1 推荐 qwen（性价比最高，¥18/万次）；本地开发用 anthropic（OAuth 免费）
LLM_PROVIDER=anthropic     # qwen | deepseek | doubao | anthropic

# Qwen（阿里云灵积/DashScope）
QWEN_API_KEY=
QWEN_MODEL=qwen-plus       # qwen-turbo（最便宜）/ qwen-plus（推荐）/ qwen-max

# DeepSeek（备份方案，工具调用强但贵 3 倍）
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# 豆包（火山引擎，需要先在控制台创建 endpoint）
DOUBAO_API_KEY=
DOUBAO_MODEL=               # 你的 endpoint id

# Anthropic（本地开发，留空走 macOS keychain 的 Claude Code OAuth）
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-haiku-4-5-20251001

# ─── DB ────────────────────────────────────────────────
# 阶段 1 W1 后切 PG；本地仍可用 SQLite
HIPOP_DB=/Users/luke/code/hipop/hipop.db
# DB_URL=postgresql://user:pass@localhost:5432/hipop

# ─── ERP（dbuyerp）─────────────────────────────────────
# 现阶段靠本机 chrome 9222 抓 token；阶段 1 W3 改服务端 service account
ERP_USERNAME=
ERP_PASSWORD=

# ─── 飞书 ──────────────────────────────────────────────
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_WEBHOOK=
FEISHU_USER_TOKEN_FILE=./feishu_auth/token.json

# ─── 紫鸟 OpenAPI ──────────────────────────────────────
ZINIAO_APP_ID=
ZINIAO_APP_SECRET=         # RSA 私钥 PKCS8 base64 字符串
ZINIAO_USERNAME=
ZINIAO_PASSWORD=
ZINIAO_COMPANY=点购优品跨境

# ─── 服务 ──────────────────────────────────────────────
HIPOP_PORT=8765

# ─── Auth (W2) ────────────────────────────────────────
# JWT 签名 secret — 生产必须设固定值（重启不变，否则用户 cookie 全失效）
# 本地不设时随机生成（dev only，重启失效）
JWT_SECRET=

